{
  "name": "ifc-lite",
  "version": "2.4.0",
  "description": "High-performance browser IFC parser & renderer",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "pnpm build && pnpm --filter viewer dev",
    "dev:api": "zsh -lc 'set -a; source \"apps/api/.env.local\"; set +a; PORT=3001 tsx scripts/dev-chat-api.ts'",
    "dev:embed": "pnpm build && pnpm --filter @ifc-lite/viewer-embed dev",
    "dev:desktop": "pnpm --filter @ifc-lite/desktop dev",
    "build": "turbo build",
    "build:embed": "pnpm --filter @ifc-lite/viewer-embed build",
    "build:desktop": "pnpm --filter @ifc-lite/desktop build",
    "build:desktop:windows": "pnpm --filter @ifc-lite/desktop build:windows",
    "build:desktop:macos": "pnpm --filter @ifc-lite/desktop build:macos",
    "build:desktop:linux": "pnpm --filter @ifc-lite/desktop build:linux",
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:wasm:threaded": "THREADED=1 bash scripts/build-wasm.sh",
    "build:wasm:both": "pnpm build:wasm && pnpm build:wasm:threaded",
    "fixtures": "node scripts/fixtures/fetch-fixtures.mjs",
    "fixtures:check": "node scripts/fixtures/fetch-fixtures.mjs --check",
    "fixtures:list-missing": "node scripts/fixtures/fetch-fixtures.mjs --list",
    "fixtures:manifest": "node scripts/fixtures/build-manifest.mjs",
    "fixtures:upload": "node scripts/fixtures/upload-fixtures.mjs",
    "test": "turbo test",
    "test:collab": "pnpm --filter @ifc-lite/collab --filter @ifc-lite/collab-server test",
    "test:api": "tsx --test \"tests/api/**/*.test.ts\"",
    "test:regression": "node scripts/test-geometry-regression.mjs",
    "test:esm": "node scripts/verify-esm-entrypoints.mjs",
    "test:ids-corpus": "node scripts/test-ids-corpus.mjs",
    "collab:server": "pnpm turbo build --filter=@ifc-lite/collab-server && node packages/collab-server/dist/bin.js",
    "collab:demo": "pnpm turbo build --filter=@ifc-lite/collab --filter=@ifc-lite/collab-server && node scripts/collab-demo.mjs",
    "collab:demo:3d": "pnpm turbo build --filter=@ifc-lite/collab --filter=@ifc-lite/collab-server && node scripts/collab-demo-3d.mjs",
    "typecheck": "turbo typecheck",
    "lint": "pnpm -r lint",
    "docs:serve": "python3 -m mkdocs serve",
    "docs:build": "python3 -m mkdocs build",
    "changeset": "changeset",
    "version": "changeset version && node scripts/sync-versions.js",
    "release": "pnpm build && pnpm test:esm && pnpm release:npm && pnpm release:crates",
    "release:npm": "changeset publish",
    "release:crates": "cargo publish -p ifc-lite-core --allow-dirty || true && sleep 30 && cargo publish -p ifc-lite-geometry --allow-dirty || true && sleep 30 && cargo publish -p ifc-lite-wasm --allow-dirty || true",
    "publish:npm": "pnpm -r publish --access public",
    "publish:dry": "pnpm -r publish --access public --dry-run",
    "test:benchmark": "playwright test tests/benchmark/benchmark.spec.ts",
    "test:benchmark:headed": "playwright test tests/benchmark/benchmark.spec.ts --headed",
    "test:benchmark:viewer": "playwright test tests/benchmark/viewer-benchmark.spec.ts --project=viewer-benchmark",
    "test:benchmark:viewer:ci": "playwright test tests/benchmark/viewer-benchmark.spec.ts --project=viewer-benchmark-ci --reporter=json",
    "benchmark:node": "node tests/benchmark/run-benchmark.mjs",
    "benchmark:viewer:upstream": "node tests/benchmark/run-viewer-benchmark-upstream.mjs",
    "benchmark:viewer:upstream:ci": "PLAYWRIGHT_PROJECT=viewer-benchmark-ci node tests/benchmark/run-viewer-benchmark-upstream.mjs",
    "benchmark:check": "node scripts/check-benchmark-regression.js",
    "benchmark:baseline": "pnpm --filter viewer build && pnpm test:benchmark:viewer",
    "generate:bim-globals": "tsx scripts/generate-bim-globals.ts",
    "generate:epsg-index": "tsx scripts/generate-epsg-index.ts",
    "check:templates": "pnpm --filter viewer check:templates"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=8.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2"
  }
}
