{
  "name": "@ifc-lite/cli",
  "version": "0.7.0",
  "description": "CLI toolkit for IFC files — query, validate, export, create, and script BIM data",
  "type": "module",
  "bin": {
    "ifc-lite": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@ifc-lite/parser": "workspace:^",
    "@ifc-lite/query": "workspace:^",
    "@ifc-lite/data": "workspace:^",
    "@ifc-lite/sdk": "workspace:^",
    "@ifc-lite/export": "workspace:^",
    "@ifc-lite/ids": "workspace:^",
    "@ifc-lite/bcf": "workspace:^",
    "@ifc-lite/create": "workspace:^",
    "@ifc-lite/encoding": "workspace:^",
    "@ifc-lite/sandbox": "workspace:^",
    "@ifc-lite/mutations": "workspace:^",
    "@ifc-lite/mcp": "workspace:^",
    "@ifc-lite/wasm": "workspace:^",
    "@ifc-lite/viewer-core": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/louistrue/ifc-lite.git",
    "directory": "packages/cli"
  },
  "homepage": "https://louistrue.github.io/ifc-lite/",
  "bugs": "https://github.com/louistrue/ifc-lite/issues",
  "keywords": [
    "ifc",
    "bim",
    "cli",
    "aec",
    "building",
    "construction",
    "ifc-lite"
  ],
  "publishConfig": {
    "access": "public"
  }
}
