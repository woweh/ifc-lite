{
  "name": "@ifc-lite/collab-server",
  "version": "0.1.0",
  "description": "Reference websocket sync server for @ifc-lite/collab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ifc-lite-collab-server": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./room-manager": {
      "import": "./dist/room-manager.js",
      "types": "./dist/room-manager.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "start": "node ./dist/bin.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@ifc-lite/collab": "workspace:^",
    "lib0": "^0.2.99",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "y-websocket": "^2.0.4"
  },
  "license": "MPL-2.0",
  "author": "Louis True",
  "repository": {
    "type": "git",
    "url": "https://github.com/louistrue/ifc-lite.git",
    "directory": "packages/collab-server"
  },
  "homepage": "https://louistrue.github.io/ifc-lite/",
  "bugs": "https://github.com/louistrue/ifc-lite/issues",
  "keywords": [
    "ifc",
    "ifcx",
    "bim",
    "collaboration",
    "crdt",
    "yjs",
    "websocket"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
